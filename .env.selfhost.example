# Self-hosting starter .env — copy to .env and fill in the secrets.
# Generate secrets:
#   NEXTAUTH_SECRET      → openssl rand -base64 32
#   CALENDSO_ENCRYPTION_KEY → openssl rand -hex 32

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=unicorn_user
POSTGRES_PASSWORD=magical_password
POSTGRES_DB=calendso
DATABASE_HOST=database
DATABASE_URL=postgresql://unicorn_user:magical_password@database/calendso
DATABASE_DIRECT_URL=postgresql://unicorn_user:magical_password@database/calendso

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_EMBED_LIB_URL=http://localhost:3000/embed/embed.js
NEXTAUTH_URL=http://localhost:3000

# ── Secrets (REQUIRED — generate fresh values) ───────────────────────────────
NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32
CALENDSO_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ── API v2 ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_V2_URL=http://localhost:80
API_URL=http://localhost:80
API_PORT=80
WEB_APP_URL=http://localhost:3000
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
API_KEY_PREFIX=cal_
REWRITE_API_V2_PREFIX=true
LOG_LEVEL=info

# ── Misc ──────────────────────────────────────────────────────────────────────
CALCOM_TELEMETRY_DISABLED=1
NODE_ENV=production
CRON_API_KEY=0cc0e6c35519bba620c9360cfe3e68d0
NEXT_PUBLIC_LICENSE_CONSENT=agree
IS_TEAM_BILLING_ENABLED=false
ALLOWED_HOSTNAMES='"localhost:3000"'

# ── Stripe (leave blank until integration) ───────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
