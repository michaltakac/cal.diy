# Self-hosting starter .env — copy to .env and fill in the secrets.
# Generate secrets:
#   NEXTAUTH_SECRET      → openssl rand -base64 32
#   CALENDSO_ENCRYPTION_KEY → openssl rand -hex 32

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=unicorn_user
POSTGRES_PASSWORD=magical_password
POSTGRES_DB=calendso
DATABASE_HOST=database
DATABASE_URL=postgresql://unicorn_user:magical_password@database/calendso
DATABASE_DIRECT_URL=postgresql://unicorn_user:magical_password@database/calendso

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_EMBED_LIB_URL=http://localhost:3000/embed/embed.js
NEXTAUTH_URL=http://localhost:3000

# ── Secrets (REQUIRED — generate fresh values) ───────────────────────────────
NEXTAUTH_SECRET=REPLACE_WITH_openssl_rand_base64_32
CALENDSO_ENCRYPTION_KEY=REPLACE_WITH_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ── API v2 ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_V2_URL=http://localhost:80
API_URL=http://localhost:80
API_PORT=80
WEB_APP_URL=http://localhost:3000
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
API_KEY_PREFIX=cal_
REWRITE_API_V2_PREFIX=true
LOG_LEVEL=info

# ── Misc ──────────────────────────────────────────────────────────────────────
CALCOM_TELEMETRY_DISABLED=1
NODE_ENV=production
CRON_API_KEY=0cc0e6c35519bba620c9360cfe3e68d0
NEXT_PUBLIC_LICENSE_CONSENT=agree
IS_TEAM_BILLING_ENABLED=false
ALLOWED_HOSTNAMES='"localhost:3000"'

# ── Stripe (fiat payments — Cal's native Stripe app) ─────────────────────────
# The native Cal Stripe app uses Stripe Connect. These six vars are read by
# `scripts/seed-app-store.ts` to seed the `stripe` app row (App.keys) and by
# StripePaymentService at runtime. All six MUST be set for the app to enable.
#
# TEST MODE (default for non-live work): use Stripe *test-mode* values —
#   STRIPE_PRIVATE_KEY -> sk_test_...   NEXT_PUBLIC_STRIPE_PUBLIC_KEY -> pk_test_...
# LIVE cut-over: replace with the board-provided LIVE keys (sk_live_/pk_live_).
# Board/CEO owns providing the real account keys — do NOT commit real secrets.
STRIPE_CLIENT_ID=ca_REPLACE_WITH_STRIPE_CONNECT_CLIENT_ID
STRIPE_PRIVATE_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SIGNING_SECRET
# Platform fee taken on each paid booking. Single-tenant self-host = 0/0.
PAYMENT_FEE_FIXED=0
PAYMENT_FEE_PERCENTAGE=0
